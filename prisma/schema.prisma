generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  PHYSICIAN
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  role         UserRole   @default(PHYSICIAN)
  physician    Physician?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Physician {
  id        String @id @default(cuid())
  userId    String @unique
  user      User   @relation(fields: [userId], references: [id])
  firstName String
  lastName  String
  phone     String?

  fteDays Int @default(200)

  isInterventionalist Boolean @default(false)
  isEP                Boolean @default(false)

  eligibilities        PhysicianEligibility[]
  officeDays           PhysicianOfficeDay[]
  assignments          ScheduleAssignment[]
  vacationRequests     VacationRequest[]
  noCallDayRequests    NoCallDayRequest[]
  swapRequestsFrom     SwapRequest[]        @relation("SwapFrom")
  swapRequestsTo       SwapRequest[]        @relation("SwapTo")
  holidayAssignments   HolidayAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum RoleCategory {
  ON_CALL
  DAYTIME
  READING
  SPECIAL
}

model RoleType {
  id          String       @id @default(cuid())
  name        String       @unique
  displayName String
  category    RoleCategory
  description String?
  sortOrder   Int          @default(0)

  minRequired Int @default(1)
  maxRequired Int @default(1)

  eligibilities      PhysicianEligibility[]
  assignments        ScheduleAssignment[]
  rules              SchedulingRule[]
  holidayAssignments HolidayAssignment[]
  swapRequests       SwapRequest[]

  createdAt DateTime @default(now())
}

model PhysicianEligibility {
  id           String    @id @default(cuid())
  physicianId  String
  physician    Physician @relation(fields: [physicianId], references: [id], onDelete: Cascade)
  roleTypeId   String
  roleType     RoleType  @relation(fields: [roleTypeId], references: [id], onDelete: Cascade)

  @@unique([physicianId, roleTypeId])
}

model PhysicianOfficeDay {
  id          String    @id @default(cuid())
  physicianId String
  physician   Physician @relation(fields: [physicianId], references: [id], onDelete: Cascade)
  dayOfWeek   Int

  @@unique([physicianId, dayOfWeek])
}

enum RuleType {
  EXCLUSION
  PREREQUISITE
  DISTRIBUTION
  CONFLICT
}

model SchedulingRule {
  id          String    @id @default(cuid())
  name        String
  description String?
  ruleType    RuleType
  roleTypeId String?
  roleType   RoleType? @relation(fields: [roleTypeId], references: [id])
  parameters Json
  isActive   Boolean   @default(true)
  priority   Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ScheduleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Schedule {
  id          String         @id @default(cuid())
  year        Int            @unique
  status      ScheduleStatus @default(DRAFT)
  generatedAt DateTime?
  publishedAt DateTime?
  publishedBy String?

  assignments ScheduleAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum AssignmentSource {
  AUTO
  MANUAL
  SWAP
  BACKFILL
}

model ScheduleAssignment {
  id          String           @id @default(cuid())
  scheduleId  String
  schedule    Schedule         @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  date        DateTime         @db.Date
  physicianId String
  physician   Physician        @relation(fields: [physicianId], references: [id])
  roleTypeId  String
  roleType    RoleType         @relation(fields: [roleTypeId], references: [id])
  source      AssignmentSource @default(AUTO)
  isActive    Boolean          @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([scheduleId, date, roleTypeId])
  @@index([date])
  @@index([physicianId])
}

enum RequestStatus {
  PENDING
  APPROVED
  DENIED
  CANCELLED
}

model VacationRequest {
  id               String        @id @default(cuid())
  physicianId      String
  physician        Physician     @relation(fields: [physicianId], references: [id])
  startDate        DateTime      @db.Date
  endDate          DateTime      @db.Date
  reason           String?
  status           RequestStatus @default(PENDING)
  reviewedBy       String?
  reviewedAt       DateTime?
  reviewNote       String?
  conflictAnalysis Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NoCallDayRequest {
  id           String        @id @default(cuid())
  physicianId  String
  physician    Physician     @relation(fields: [physicianId], references: [id])
  date         DateTime      @db.Date
  reason       String?
  status       RequestStatus @default(PENDING)
  reviewedBy   String?
  reviewedAt   DateTime?
  reviewNote   String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([physicianId, date])
  @@index([date])
}

model SwapRequest {
  id              String        @id @default(cuid())
  fromPhysicianId String
  fromPhysician   Physician     @relation("SwapFrom", fields: [fromPhysicianId], references: [id])
  toPhysicianId   String
  toPhysician     Physician     @relation("SwapTo", fields: [toPhysicianId], references: [id])
  date            DateTime      @db.Date
  roleTypeId      String
  roleType        RoleType      @relation(fields: [roleTypeId], references: [id])
  status          RequestStatus @default(PENDING)
  peerAccepted    Boolean       @default(false)
  peerAcceptedAt  DateTime?
  adminApproved   Boolean       @default(false)
  adminApprovedAt DateTime?
  reviewNote      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Holiday {
  id          String              @id @default(cuid())
  name        String              @unique
  weight      Int                 @default(1)
  assignments HolidayAssignment[]
}

model HolidayAssignment {
  id          String    @id @default(cuid())
  holidayId   String
  holiday     Holiday   @relation(fields: [holidayId], references: [id])
  physicianId String
  physician   Physician @relation(fields: [physicianId], references: [id])
  year        Int
  roleTypeId  String
  roleType    RoleType  @relation(fields: [roleTypeId], references: [id])

  @@unique([holidayId, year, roleTypeId])
  @@index([physicianId])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  entityType String
  entityId   String
  details    Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}
